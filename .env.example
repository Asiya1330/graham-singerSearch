# Copy to .env for local dev — NEVER commit .env
# cp .env.example .env

# --- Supabase (Dashboard → Project Settings → API) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Dashboard → Database → Connection string → Transaction pooler, port 6543)
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# Storage bucket name (Dashboard → Storage → create public bucket)
SUPABASE_STORAGE_BUCKET=your-bucket-name

# --- App secrets (generate strong random values) ---
SESSION_SECRET=replace-with-long-random-string-min-32-chars
ADMIN_PASSWORD=replace-with-strong-admin-password

# --- Local dev ---
NODE_ENV=development
PORT=5000

# --- Railway only (API deploy) ---
# SERVE_CLIENT=false
# SITE_URL=https://your-production-domain.com
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=Your App <notifications@your-domain.com>
# ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com
# SUPPORT_EMAIL=support@your-domain.com
# EMAIL_NOTIFICATIONS_ENABLED=true
# EMAIL_LOGO_URL=https://your-production-domain.com/singer-search-logo.png

# --- Vercel only (frontend deploy) ---
# RAILWAY_API_URL=https://your-service.up.railway.app

# --- Local dev only (optional login form prefill — NEVER use production credentials) ---
# VITE_DEMO_SINGER_EMAIL=demo@example.com
# VITE_DEMO_SINGER_PASSWORD=demo-password

# Supabase (Project Settings → API)
SUPABASE_URL=https://tncpvoajbkwdmsodsmom.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase → Database → Connection string → Transaction pooler (URI, port 6543)
SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Storage bucket (create in Dashboard → Storage, set to Public)
SUPABASE_STORAGE_BUCKET=singer-uploads

# App secrets
SESSION_SECRET=generate-a-long-random-string
ADMIN_PASSWORD=your-admin-password

# Local dev
NODE_ENV=development
PORT=5000

# Railway API-only deploy (Vercel serves the frontend)
# SERVE_CLIENT=false

# Public site URL — Railway only; password-reset links, email CTAs, logo URL (see SETUP-EMAIL.md)
# Production (custom domain):
# SITE_URL=https://singersearch.com
# Sandbox / preview:
# SITE_URL=https://graham-singer-search.vercel.app

# Vercel only — proxy /api/* to Railway (see SETUP-PREVIEW-DEPLOY.md)
# Production scope: production Railway URL
# Preview scope: preview Railway URL (e.g. email-integration branch)
# RAILWAY_API_URL=https://singersearch-production.up.railway.app
# Must include https:// — no trailing slash, no /api suffix

# Email notifications (Resend) — Railway only; see SETUP-EMAIL.md
# RESEND_API_KEY=re_xxxxxxxx
# Production (verified domain singersearch.com):
# RESEND_FROM_EMAIL=Singer Search <notifications@singersearch.com>
# Sandbox only:
# RESEND_FROM_EMAIL=onboarding@resend.dev
# ADMIN_NOTIFICATION_EMAIL=admin@singersearch.com
# SUPPORT_EMAIL=support@singersearch.com
# EMAIL_NOTIFICATIONS_ENABLED=true
# EMAIL_LOGO_URL=https://singersearch.com/singer-search-logo.png
